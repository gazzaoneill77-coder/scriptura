---
// Pre-launch landing page. Ship this FIRST — point the domain here while
// samples are still on the press, and collect demand before the store opens.
import Base from '../layouts/Base.astro';
import GateList from '../components/GateList.astro';
---
<Base title="THE GATE LIST" bare>
  <div class="gate-hero">
    <h1>NARROW.</h1>
    <p class="scripture" style="margin-top:24px">“Narrow is the gate, and few find it.”</p>
    <p class="sub" style="margin-top:12px;color:var(--dim);font-size:13px;letter-spacing:0.2em;text-transform:uppercase">Heavyweight streetwear for the hard road.</p>

    <div style="margin-top:72px;max-width:520px">
      <p class="kicker">DROP 001 — TESTAMENT</p>
      <p style="color:var(--dim);margin-top:12px">Five pieces. One story. Limited numbers.<br />Drops are announced here first. Position matters.</p>
      <GateList />
    </div>
  </div>
</Base>
