---
import Base from '../../layouts/Base.astro';
import data from '../../data/products.json';
import site from '../../data/site.json';

export function getStaticPaths() {
  return data.products.map((product) => ({ params: { slug: product.slug }, props: { product } }));
}

const { product } = Astro.props;
const gbp = (pence) => `£${(pence / 100).toFixed(2).replace(/\.00$/, '')}`;
const sizes = Object.keys(product.stock);
const clientData = {
  sku: product.sku,
  slug: product.slug,
  name: product.name,
  price: product.price,
  stock: product.stock,
  lowStockThreshold: site.lowStockThreshold
};
---
<Base title={product.name} description={product.description[0]}>
  <div class="wrap">
    <div class="pdp">
      <div class="frame">
        <img src={product.mark} alt={`${product.name} — ${product.scripture}`} />
      </div>
      <div>
        <p class="kicker">DROP {data.drop.number} — {data.drop.name}</p>
        <h1 style={product.featured ? `color:${product.accent}` : undefined}>{product.name}</h1>
        <p class="scripture">{product.scripture}</p>
        <p class="price">{gbp(product.price)}</p>

        <div class="desc">
          {product.description.map((line) => <p>{line}</p>)}
        </div>

        <div class="sizes" role="group" aria-label="Select size">
          {sizes.map((size) => (
            <button class="size-btn" data-size={size} aria-pressed="false">{size}</button>
          ))}
        </div>
        <p class="low-stock" data-stock-msg></p>

        <button class="btn solid claim" data-claim disabled>CLAIM IT</button>
        <p class="trust-line">Hand-pressed in the UK. Tracked shipping. 14-day returns.</p>

        <ul class="details">
          {product.details.map((d) => <li>— {d}</li>)}
        </ul>

        <p class="closing">{product.closingLine}</p>
      </div>
    </div>
  </div>

  <script type="application/json" id="product-data" set:html={JSON.stringify(clientData)} />
</Base>
