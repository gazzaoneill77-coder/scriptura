---
import Base from '../layouts/Base.astro';
import data from '../data/products.json';
import { href } from '../lib/url.js';

const story = [...data.products].sort((a, b) => a.order - b.order);
const storyLabels = {
  valley: ['TRIAL.', 'Valley.'],
  armour: ['PROTECTION.', 'Armour.'],
  refined: ['REFINEMENT.', 'Refined.'],
  judah: ['VICTORY.', 'Judah.'],
  'alpha-omega': ['ETERNITY.', 'Alpha/Omega.']
};

// Cube faces: front is the wordmark, the other five carry the piece marks.
const faces = ['front', 'back', 'right', 'left', 'top', 'bottom'];
---
<Base>
  <section class="hero">
    <div class="cube-stage" aria-hidden="true">
      <div class="cube">
        {faces.map((face, i) => (
          <div class={`face ${face}`}>
            {i === 0 ? <span class="face-word">N.</span> : <img src={href(story[i - 1].mark)} alt="" loading="eager" />}
          </div>
        ))}
      </div>
    </div>
    <h1>NARROW.</h1>
    <p class="scripture">“Narrow is the gate, and few find it.”</p>
    <p class="sub">Heavyweight streetwear for the hard road.</p>
    <a class="btn" href={href('/shop')}>ENTER</a>
  </section>

  <section class="band center">
    <div class="wrap reveal">
      <p class="kicker">DROP {data.drop.number}</p>
      <h2>{data.drop.name}</h2>
      <p class="lead">{data.drop.tagline}<br />When they're gone, they're gone. No restocks. No exceptions.</p>
      <div class="cta-row">
        <a class="btn solid" href={href('/shop')}>SHOP THE DROP</a>
        <a class="btn ghost" href="#gate">GET NOTIFIED</a>
      </div>
    </div>
  </section>

  <section class="band center">
    <div class="wrap">
      <p class="kicker reveal">ONE STORY. FIVE PIECES.</p>
      <div class="story-strip">
        {story.map((p) => (
          <a class="story-cell reveal tilt" href={href(`/products/${p.slug}`)}>
            <img src={href(p.mark)} alt={p.name} loading="lazy" />
            <div class="label">
              <strong>{storyLabels[p.slug][0]}</strong>
              <span>{storyLabels[p.slug][1]}</span>
            </div>
          </a>
        ))}
      </div>
      <p class="story-foot reveal">Wear the whole walk. Or start where you are.</p>
    </div>
  </section>

  <section class="band center craft" id="gate">
    <div class="wrap reveal">
      <p class="kicker">THE PRESS</p>
      <p>Printed by hand. Pressed one at a time. Heavyweight cotton that holds its shape after the fiftieth wash. We don't do fast fashion. We do few.</p>
    </div>
  </section>
</Base>
