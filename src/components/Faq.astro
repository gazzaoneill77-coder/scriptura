---
// Renders a Frequently Asked Questions block plus FAQPage structured data.
// This is the core of Answer Engine Optimisation: each Q&A is a candidate for a
// featured snippet, a voice answer, or a direct AI citation. The visible text
// and the schema are generated from the same source, so they always match
// (Google requires that).
import JsonLd from './JsonLd.astro';

const { faqs = [], heading = 'Frequently asked questions', withSchema = true } =
  Astro.props;

const schema =
  withSchema && faqs.length
    ? {
        '@context': 'https://schema.org',
        '@type': 'FAQPage',
        mainEntity: faqs.map((f) => ({
          '@type': 'Question',
          name: f.q,
          acceptedAnswer: { '@type': 'Answer', text: f.a }
        }))
      }
    : null;
---
{faqs.length > 0 && (
  <section class="faq" aria-labelledby="faq-heading">
    <h2 id="faq-heading" class="faq__heading">{heading}</h2>
    <div class="faq__list">
      {faqs.map((f) => (
        <details class="faq__item">
          <summary class="faq__q">{f.q}</summary>
          <div class="faq__a"><p>{f.a}</p></div>
        </details>
      ))}
    </div>
    {schema && <JsonLd schema={schema} />}
  </section>
)}
