---
import site from '../data/site.json';
---
<form
  class="gate-form"
  method="post"
  action={site.gateList.formAction || undefined}
  data-gate-form
  data-endpoint={site.gateList.formAction}
>
  <input
    type="email"
    name={site.gateList.emailFieldName}
    placeholder="your email"
    required
    autocomplete="email"
    aria-label="Email address"
  />
  <button type="submit" class="btn solid">FIND IT</button>
</form>
<p class="gate-msg" data-gate-msg></p>

<script>
  // Signups post to the form relay in site.json → gateList.formAction
  // (FormSubmit AJAX — key-free; the first submission emails the owner an
  // activation link). If the network call fails, the address is held in
  // localStorage so no early signup is ever lost.
  document.querySelectorAll('[data-gate-form]').forEach((form) => {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const msg = form.parentElement.querySelector('[data-gate-msg]');
      const input = form.querySelector('input[type="email"]');
      const email = input.value.trim();
      if (!email) return;

      const done = () => {
        input.value = '';
        if (msg) msg.textContent = 'You found it. You’re on the list.';
      };
      const hold = () => {
        const held = JSON.parse(localStorage.getItem('narrow.gatelist') || '[]');
        if (!held.includes(email)) held.push(email);
        localStorage.setItem('narrow.gatelist', JSON.stringify(held));
        done();
      };

      const endpoint = form.dataset.endpoint;
      if (!endpoint) return hold();

      form.querySelector('button').disabled = true;
      try {
        const res = await fetch(endpoint, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json', Accept: 'application/json' },
          body: JSON.stringify({ _subject: 'NARROW. — Gate List signup', email })
        });
        if (!res.ok) throw new Error('relay error');
        done();
      } catch {
        hold();
      } finally {
        form.querySelector('button').disabled = false;
      }
    });
  });
</script>
