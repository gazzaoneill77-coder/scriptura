---
import site from '../data/site.json';
---
<form
  class="gate-form"
  method="post"
  action={site.gateList.formAction || undefined}
  data-gate-form
  data-configured={site.gateList.formAction ? 'true' : 'false'}
>
  <input
    type="email"
    name={site.gateList.emailFieldName}
    placeholder="your email"
    required
    autocomplete="email"
    aria-label="Email address"
  />
  <button type="submit" class="btn solid">FIND IT</button>
</form>
<p class="gate-msg" data-gate-msg></p>

<script>
  // Until a list provider is wired up (site.json → gateList.formAction),
  // submissions are held in localStorage so early signups aren't lost.
  document.querySelectorAll('[data-gate-form]').forEach((form) => {
    form.addEventListener('submit', (e) => {
      const msg = form.parentElement.querySelector('[data-gate-msg]');
      if (form.dataset.configured === 'true') return; // real provider handles it
      e.preventDefault();
      const email = form.querySelector('input[type="email"]').value.trim();
      if (!email) return;
      const held = JSON.parse(localStorage.getItem('narrow.gatelist') || '[]');
      if (!held.includes(email)) held.push(email);
      localStorage.setItem('narrow.gatelist', JSON.stringify(held));
      form.querySelector('input').value = '';
      if (msg) msg.textContent = 'You found it. You’re on the list.';
    });
  });
</script>
