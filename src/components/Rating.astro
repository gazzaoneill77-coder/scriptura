---
// Accessible star rating. Renders a precise, half-star-capable visual plus a
// screen-reader label and a numeric value. The number is what schema and AI
// engines read; the stars are for humans.
const { value = 0, max = 5, showValue = true } = Astro.props;
const pct = Math.max(0, Math.min(100, (value / max) * 100));
const label = `${value} out of ${max}`;
---
<span class="rating" role="img" aria-label={label}>
  <span class="rating__stars" aria-hidden="true">
    <span class="rating__fill" style={`width:${pct}%`}>★★★★★</span>
    <span class="rating__base">★★★★★</span>
  </span>
  {showValue && <span class="rating__value">{value.toFixed(1)}</span>}
</span>
