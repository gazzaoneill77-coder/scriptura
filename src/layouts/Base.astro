---
import site from '../data/site.json';
import GateList from '../components/GateList.astro';
import '../styles/global.css';

const { title, description = 'NARROW. Heavyweight streetwear for the hard road. Few find it.', bare = false } = Astro.props;
const path = Astro.url.pathname;
const current = (href) => (path === href || path === `${href}/` ? 'page' : undefined);
---
<html lang="en-GB">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title ? `${title} — NARROW.` : 'NARROW. — Few find it.'}</title>
    <meta name="description" content={description} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Archivo:wght@400;600&family=Cormorant+Garamond:ital,wght@0,500;0,600;0,700;1,500&display=swap" rel="stylesheet" />
    <link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 32 32'><rect width='32' height='32' fill='%23070707'/><text x='16' y='23' text-anchor='middle' fill='%23e8e4da' font-family='Georgia' font-size='20'>N.</text></svg>" />
  </head>
  <body>
    {!bare && (
      <>
        <div class="announce">{site.announcement}</div>
        <header class="site">
          <div class="bar">
            <a class="logo" href="/">NARROW.</a>
            <nav class="main">
              <a href="/shop" aria-current={current('/shop')}>THE DROP</a>
              <a href="/the-road" aria-current={current('/the-road')}>THE ROAD</a>
              <a href="/faq" aria-current={current('/faq')}>QUESTIONS.</a>
              <a href="/cart" class="cart-link" aria-current={current('/cart')}>
                CART
                <span class="cart-count" data-cart-count></span>
              </a>
            </nav>
          </div>
        </header>
      </>
    )}

    <slot />

    {!bare && (
      <footer class="site">
        <h2>THE GATE LIST.</h2>
        <p class="lead">Drops are announced here first. Numbers are limited. Position matters.</p>
        <GateList />
        <div class="foot-meta">
          <span>NARROW. — Few find it.</span>
          <nav>
            <a href="/shop">THE DROP</a>
            <a href="/the-road">THE ROAD</a>
            <a href="/faq">QUESTIONS.</a>
          </nav>
        </div>
      </footer>
    )}

    <script src="../scripts/cart.js"></script>
  </body>
</html>
